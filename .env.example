# ---------------------------------------------------------------
# Local development — copy this file to .env and fill in values
# ---------------------------------------------------------------

# Database
# Local SQLite for development:
DATABASE_URL="file:./dev.db"
# Production (Netlify Database — set automatically via NETLIFY_DB_URL in netlify.toml):
# DATABASE_URL="postgresql://user:password@host:5432/database"

# NextAuth
NEXTAUTH_SECRET="your-secret-key-change-in-production"
# Required in production; optional locally (defaults to http://localhost:3000)
NEXTAUTH_URL="http://localhost:3000"

# Google OAuth (optional — omit both to disable Google sign-in)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Cron secret — used to authenticate the /api/sync RSS feed endpoint
CRON_SECRET="your-cron-secret-change-in-production"
